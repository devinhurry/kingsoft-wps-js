    "ms-doc",
    "parser",
    "javascript",
    "nodejs"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devinhurry/msdoc-wps-parser-js.git"
  },
  "bugs": {
    "url": "https://github.com/devinhurry/msdoc-wps-parser-js/issues"
  },
  "homepage": "https://github.com/devinhurry/msdoc-wps-parser-js#readme",
  "engines": {
    "node": ">=18"
