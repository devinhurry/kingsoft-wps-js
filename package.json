{
  "name": "msdoc-wps-parser",
  "version": "0.1.0",
  "description": "Pure JavaScript reader for Kingsoft/WPS Office OLE2 .wps files backed by Word binary streams.",
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "bin",
    "src",
